{
  "name": "viralflow",
  "version": "0.4.0",
  "description": "Platform-agnostic content discovery, angle generation, and performance analytics system",
  "author": "Steve Westhoek",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevewesthoek/viralflow.git"
  },
  "homepage": "https://github.com/stevewesthoek/viralflow",
  "bugs": {
    "url": "https://github.com/stevewesthoek/viralflow/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "ABOUT.md",
    "ARCHITECTURE.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '**/*.md'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "prepare": "npm run build",
    "pretest": "npm run lint",
    "cli": "ts-node src/cli.ts"
  },
  "keywords": [
    "content-strategy",
    "viral",
    "discovery",
    "angles",
    "hooks",
    "social-media",
    "youtube",
    "tiktok",
    "instagram",
    "platform-agnostic"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.54.0",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  },
  "bin": {
    "viral-flow": "dist/cli.js"
  }
}
