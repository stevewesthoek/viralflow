# Viral Flow — Required Environment Variables
# Copy this file to .env (never commit .env with real keys!)

# === DISCOVERY SOURCES ===

# YouTube Data API v3 (for topic discovery)
# Get it: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
# Leave unset to fall back to mock data
YOUTUBE_API_KEY=your_youtube_api_key_here

# Reddit OAuth (for topic discovery)
# Get it: https://www.reddit.com/prefs/apps → create "personal use" script
# Leave unset to fall back to mock data
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Twitter/X API v2 (for trending topics)
# Get it: https://developer.twitter.com/en/portal/dashboard
# Leave unset if not using Twitter discovery
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# TikTok Research API (for trending hashtags)
# Separate from posting API — requires separate developer app
# Get it: https://developer.tiktok.com/
TIKTOK_RESEARCH_CLIENT_KEY=your_tiktok_research_key

# === POSTING ADAPTERS ===

# YouTube Posting OAuth (for uploading videos)
YOUTUBE_OAUTH_CLIENT_ID=your_oauth_client_id
YOUTUBE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback

# TikTok Posting API (for uploading videos)
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# === PERFORMANCE ===

# Cache TTL for discovery results (minutes, default 60)
VIRAL_FLOW_CACHE_TTL_MINUTES=60

# Brain data location (default ~/.viral-flow/agent-brain.json)
# VIRAL_FLOW_BRAIN_PATH=~/.viral-flow/agent-brain.json
